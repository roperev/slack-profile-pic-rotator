# Slack app credentials from https://api.slack.com/apps/YOUR_APP_ID
# OAuth & Permissions: add redirect URI http://localhost:4000/slack/callback or your ngrok URL
# User Token Scopes: add users.profile:write
SLACK_CLIENT_ID=your_slack_client_id
SLACK_CLIENT_SECRET=your_slack_client_secret
# Use http://localhost:4000/slack/callback if Slack allows it; otherwise use an HTTPS tunnel URL (e.g. ngrok)
SLACK_REDIRECT_URI=http://localhost:4000/slack/callback
